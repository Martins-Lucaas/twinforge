<?xml version="1.0"?>
<!--
  touch_tool_square_20x20.urdf
  TCP de palpação quadrado 20×20 mm para o Touch Pack (Gazebo Classic).

  Geometria da malha (STL, unidade original: mm):
    X: ±45 mm  (largura 90 mm — base de montagem)
    Y: ±45 mm  (profundidade 90 mm)
    Z: -6.5 mm … +108 mm  (comprimento total ≈ 114.5 mm)

  Cadeia de links:
    Link6 → force_sensor_link (Célula de carga 100 kg montada) → touch_tool_link → tcp_link

  Convenção de frames:
    • force_sensor_link / origem: centro do acoplador-robô, assenta plano no
      flange (Link6). Montagem AXIAL da célula CSA/ZL tipo S de 100 kg
      (CelulaDeCarga_100kg_Montagem, gerada por scripts/): acoplador ⌀63,5×8 mm
      + célula S 50,8×19,1×76,2 mm + acoplador ⌀63,5×8 mm — os recuos dos
      acopladores encaixam as faces da célula e alojam o parafuso M12 (sem
      rosca exposta); pilha coaxial a +Z, topo em Z=+92,2 mm.
    • touch_tool_link / origem: topo do acoplador-tool (0, 0, +92,2 mm no frame
      do flange), alinhado ao Link6. O fundo do STL (Z = -6.5 mm na malha) é
      alinhado com +0.0065 m.
    • tcp_link: face de contato quadrada 20×20 mm (ponta do probe), +114.5 mm acima
      da base do tool → TCP em (0, 0, +206,7 mm) no frame do flange (Link6).

  Uso standalone (Gazebo):
    Altere o parent do joint "touch_tool_attach" de "Link6" para "world",
    remova o joint "world_to_base" abaixo e spawn via spawn_entity.py.

  Integração no launch (típico):
    Injete o conteúdo entre <robot>…</robot> no URDF combinado do CR10,
    após a definição de Link6, e remova o bloco <robot name="standalone"> deste
    arquivo (use apenas o corpo interno como fragmento xacro/snippet).
-->
<robot name="touch_tool_tcp">

  <!-- ══════════════════════════════════════════════════════════════════
       ROOT (modo standalone): liga a ferramenta ao world para teste.
       Na integração com o CR10 este bloco é substituído por Link6
       como parent direto do joint "touch_tool_attach".
  ══════════════════════════════════════════════════════════════════ -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="Link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Placeholder Link6 (robô real — substituído pelo CR10 na integração). -->
  <link name="Link6">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0.0" ixz="0.0"
               iyy="1e-9" iyz="0.0" izz="1e-9"/>
    </inertial>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       CÉLULA DE CARGA 100 kg MONTADA (Link6 → touch_tool)
       Montagem única (CelulaDeCarga_100kg_Montagem.stl, gerada por
       scripts/gen_loadcell_100kg_assembly_stl.py): acoplador-robô + célula
       CSA/ZL tipo S + acoplador-tool, pilha AXIAL (faces da célula encaixadas
       nos recuos dos acopladores, parafuso M12 oculto).
       Mesh (mm): origem no centro do acoplador-robô, face inferior em Z=0,
       coaxial a +Z, topo do acoplador-tool em Z=+92,2.
  ══════════════════════════════════════════════════════════════════ -->
  <link name="force_sensor_link">
    <inertial>
      <origin xyz="0 0 0.046" rpy="0 0 0"/>
      <mass value="0.800"/>
      <inertia ixx="6.9e-4" ixy="0.0" ixz="0.0"
               iyy="8.4e-4" iyz="0.0"
               izz="2.0e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/CelulaDeCarga_100kg_Montagem.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver">
        <color rgba="0.82 0.82 0.88 1.0"/>
      </material>
    </visual>
    <collision name="col_robot_plate">
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03175" length="0.008"/>
      </geometry>
    </collision>
    <collision name="col_loadcell_s">
      <origin xyz="0 0 0.0461" rpy="0 0 0"/>
      <geometry>
        <box size="0.0508 0.0191 0.0762"/>
      </geometry>
    </collision>
    <collision name="col_tool_plate">
      <origin xyz="0 0 0.0882" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03175" length="0.008"/>
      </geometry>
    </collision>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       CORPO PRINCIPAL DO TCP
  ══════════════════════════════════════════════════════════════════ -->
  <link name="touch_tool_link">

    <!--
      Inércia estimada: alumínio 6061, ≈ 150 g, corpo aproximado como
      caixa uniforme 90×90×114.5 mm:
        Ixx = Iyy = (1/12)·m·(w² + h²) = (1/12)·0.15·(0.009+0.0131) ≈ 2.65e-4 kg·m²
        Izz        = (1/12)·m·(w² + w²) = (1/12)·0.15·0.0162         ≈ 2.03e-4 kg·m²
      CoM no centro geométrico: Z_cm ≈ (6.5 + 114.5/2) mm = 63.75 mm → 0.064 m
    -->
    <inertial>
      <origin xyz="0 0 0.064" rpy="0 0 0"/>
      <mass value="0.150"/>
      <inertia ixx="2.65e-4" ixy="0.0" ixz="0.0"
               iyy="2.65e-4" iyz="0.0"
               izz="2.03e-4"/>
    </inertial>

    <!-- Visual: malha STL (mm → m via scale). Offset +0.0065 m em Z para
         alinhar o fundo do STL (Z_mesh = -6.5 mm) com a origem do link. -->
    <visual>
      <origin xyz="0 0 0.0065" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/touch_tool_square_20x20.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="tool_white">
        <color rgba="0.95 0.95 0.95 1.0"/>
      </material>
    </visual>

    <!--
      Colisão simplificada (duas caixas) — mais estável no ODE do Gazebo
      do que a malha completa com 14 822 triângulos.

      col_body  → corpo/base de montagem: cobre Z = 0 … 0.094 m
                  (90×90 mm de largura, acompanha a seção principal).
      col_tip   → haste + face 20×20 mm: cobre Z ≈ 0.087 … 0.125 m
                  (25×25 mm com 1 mm de margem lateral).
    -->
    <collision name="col_body">
      <origin xyz="0 0 0.047" rpy="0 0 0"/>
      <geometry>
        <box size="0.090 0.090 0.094"/>
      </geometry>
    </collision>

    <collision name="col_tip">
      <origin xyz="0 0 0.106" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.038"/>
      </geometry>
    </collision>

  </link>

  <!-- Frame tcp_link na face de contato (ponta do probe 20×20 mm). -->
  <link name="tcp_link"/>

  <!-- ══════════════════════════════════════════════════════════════════
       JUNTAS
       Cadeia e offsets (no frame Link6):
         force_sensor  acoplador-robô plano no flange, pilha coaxial a +Z
         touch_tool    topo do acoplador-tool: +92,2 mm em +Link6_z
         tcp_link      +114.5 mm no eixo do probe → TCP (0, 0, +206,7) mm
  ══════════════════════════════════════════════════════════════════ -->
  <!-- Acoplador-robô assenta plano no flange; montagem coaxial ao Link6. -->
  <joint name="force_sensor_attach" type="fixed">
    <parent link="Link6"/>
    <child link="force_sensor_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Touch tool no topo do acoplador-tool (Z=+92,2 mm), alinhado ao Link6. -->
  <joint name="touch_tool_attach" type="fixed">
    <parent link="force_sensor_link"/>
    <child link="touch_tool_link"/>
    <origin xyz="0 0 0.0922" rpy="0 0 0"/>
  </joint>

  <!-- tcp_link na ponta: 6.5 mm (offset base) + 108 mm (tip) = 114.5 mm. -->
  <joint name="tcp_alias_joint" type="fixed">
    <parent link="touch_tool_link"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 0.1145" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════
       PROPRIEDADES GAZEBO
  ══════════════════════════════════════════════════════════════════ -->
  <gazebo reference="touch_tool_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.60</mu1>
    <mu2>0.60</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
    <!-- touch_tool → branco -->
    <visual>
      <material>
        <ambient>0.85 0.85 0.85 1</ambient>
        <diffuse>0.95 0.95 0.95 1</diffuse>
        <specular>0.30 0.30 0.30 1</specular>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="Link6">
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="force_sensor_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.40</mu1>
    <mu2>0.40</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
    <!-- célula de carga montada → prateado (specular alto = brilho metálico) -->
    <visual>
      <material>
        <ambient>0.55 0.55 0.58 1</ambient>
        <diffuse>0.82 0.82 0.88 1</diffuse>
        <specular>0.95 0.95 1.00 1</specular>
      </material>
    </visual>
  </gazebo>

</robot>
