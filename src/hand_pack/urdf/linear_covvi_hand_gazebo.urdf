    <!-- ── Propriedades de superfície para grasping ──────────────────────
         Sem essas tags, ODE usa mu=0 nos meshes dos dedos e o objeto
         escorrega/atravessa a mão. Aplicadas em todos os elos que
         efetivamente tocam o objeto: palma (lisa) + proximais + distais
         dos 5 dedos.
           mu1/mu2  → fricção alta (segura cilindros lisos)
           kp/kd    → contato mole; kp baixo evita ejeção, kd amortece
           minDepth → permite micro-penetração antes da força repulsiva
           maxVel   → limita velocidade de correção (evita "chute")
         Tags em namespace gazebo (não ODE) — gazebo_ros as converte. -->
    <gazebo reference="lisa">
        <mu1>1.5</mu1><mu2>1.5</mu2>
        <kp>50000</kp><kd>10</kd>
        <minDepth>0.002</minDepth><maxVel>0.05</maxVel>
    </gazebo>
    <gazebo reference="thumb_proximal">
        <mu1>1.5</mu1><mu2>1.5</mu2>
        <kp>50000</kp><kd>10</kd>
        <minDepth>0.002</minDepth><maxVel>0.05</maxVel>
    </gazebo>
    <gazebo reference="thumb_distal">
        <mu1>1.5</mu1><mu2>1.5</mu2>
        <kp>50000</kp><kd>10</kd>
        <minDepth>0.002</minDepth><maxVel>0.05</maxVel>
    </gazebo>
    <gazebo reference="index_proximal">
        <mu1>1.5</mu1><mu2>1.5</mu2>
        <kp>50000</kp><kd>10</kd>
        <minDepth>0.002</minDepth><maxVel>0.05</maxVel>
    </gazebo>
    <gazebo reference="index_distal">
        <mu1>1.5</mu1><mu2>1.5</mu2>
        <kp>50000</kp><kd>10</kd>
        <minDepth>0.002</minDepth><maxVel>0.05</maxVel>
    </gazebo>
    <gazebo reference="middle_proximal">
